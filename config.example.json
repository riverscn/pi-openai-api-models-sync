{
  "pricingUrl": "https://raw.githubusercontent.com/Wei-Shaw/model-price-repo/main/model_prices_and_context_window.json",
  "include": [".*"],
  "exclude": ["audio", "realtime", "image", "embedding", "auto-review"],
  "requestTimeoutMs": 15000,
  "defaults": {
    "reasoning": false,
    "input": ["text"],
    "contextWindow": 128000,
    "maxTokens": 16384,
    "cost": {
      "input": 0,
      "output": 0,
      "cacheRead": 0,
      "cacheWrite": 0
    }
  },
  "overrides": {}
}
